# VisionVoiceAsist v5.0 — Environment configuration template
# Copy to .env and fill in your keys. Never commit .env.

# ── Cloud AI ────────────────────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_KEY=

# ElevenLabs TTS: https://elevenlabs.io → Profile → API Key
ELEVENLABS_KEY=

# ── Optional overrides ─────────────────────────────────────────────────────
# VVA_LOG_LEVEL=INFO
# VVA_CAM_INDEX=0
# VVA_YOLO_CONF=0.35
# VVA_DASHBOARD_HOST=0.0.0.0
# VVA_DASHBOARD_PORT=8080
# VVA_LOCAL_VLM=moondream2     # or smolvlm-256m
# VVA_OFFLINE_MODE=auto         # auto | always | never

# ── Privacy (GDPR Article 25) ───────────────────────────────────────────────
# VVA_PRIVACY_BLUR_FACES=true   # Blur detected faces before cloud upload
# VVA_PRIVACY_BLUR_PLATES=true  # Blur licence-plate candidates
# VVA_PRIVACY_BLUR_KSIZE=31     # Gaussian kernel size (odd integer)

# ── V2X / Smart City (MQTT) ─────────────────────────────────────────────────
# VVA_V2X_ENABLED=false
# VVA_V2X_BROKER_HOST=localhost
# VVA_V2X_BROKER_PORT=1883
# VVA_V2X_SIM_MODE=false        # true = synthetic events, no real broker
# VVA_V2X_SIM_INTERVAL_S=30.0
