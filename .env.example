# VisionVoiceAsist v5.0 — Environment configuration template
# Copy to .env and fill in your keys. Never commit .env.

# ── Cloud AI ────────────────────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_KEY=

# ElevenLabs TTS: https://elevenlabs.io → Profile → API Key
ELEVENLABS_KEY=

# ── Optional overrides ─────────────────────────────────────────────────────
# VVA_LOG_LEVEL=INFO
# VVA_CAM_INDEX=0
# VVA_YOLO_CONF=0.35
# VVA_DASHBOARD_HOST=0.0.0.0
# VVA_DASHBOARD_PORT=8080
# VVA_LOCAL_VLM=moondream2     # or smolvlm-256m
# VVA_OFFLINE_MODE=auto         # auto | always | never
